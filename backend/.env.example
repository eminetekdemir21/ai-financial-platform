# --- Veritabanı ---
POSTGRES_USER=afp_user
POSTGRES_PASSWORD=afp_password
POSTGRES_DB=afp_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://afp_user:afp_password@postgres:5432/afp_db

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Güvenlik ---
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Uygulama ---
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- LLM (Faz 6'da kullanılacak) ---
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
